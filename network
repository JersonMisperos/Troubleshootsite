Write-Host "Q::::::Q         L:::::L         H:::::::::::H" -ForegroundColor Cyan
Write-Host "Q::::::Q         L:::::L         H:::::::::::H" -ForegroundColor Cyan
Write-Host "Q::::::Q         L:::::L         H:::HHHHH:::H" -ForegroundColor Cyan
Write-Host "Q:::::::QQQQQ   LL:::::::LLLL    H:::H   H:::H" -ForegroundColor Cyan
Write-Host "QQ:::::::::QQ   L::::::::::::L   H:::H   H:::H" -ForegroundColor Cyan
